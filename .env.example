# =============================================================================
# AISprinkler – Environment Variables
# Copy to .env and fill values. Never commit .env to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Docker runtime host: db (not localhost)
DATABASE_URL=postgresql+asyncpg://aisprinkler:aisprinkler@db:5432/aisprinkler
DEVICE_ID=00000000-0000-0000-0000-000000000001
BASELINE_LOOKAHEAD_DAYS=7

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Docker runtime host: redis (not localhost)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Agent Runtime ─────────────────────────────────────────────────────────────
# heuristic (default) | langchain
AGENT_MODE=heuristic

# ── AI Provider ──────────────────────────────────────────────────────────
# Provider: openai | anthropic | ollama  (default: openai)
LLM_PROVIDER=openai

# Model override – leave blank to use the provider's default model
# openai default: gpt-4.1 | anthropic default: claude-3-7-sonnet | ollama default: llama3.2
LLM_MODEL=

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (only when LLM_PROVIDER=ollama) ────────────────────────────────
# Base URL of the running Ollama server on compose network (no API key required)
OLLAMA_BASE_URL=http://ollama:11434

# ── Weather Providers ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=...
WEATHERAPI_API_KEY=...

# Primary provider: openweathermap | weatherapi
WEATHER_PRIMARY_PROVIDER=openweathermap

# Runtime weather source for use case wiring: open_meteo | synthetic
WEATHER_PROVIDER=open_meteo

# Location parameters for weather fetches and persistence
WEATHER_LAT=30.676
WEATHER_LON=-87.914
WEATHER_ZIPCODE=36527
WEATHER_CITY=Spanish Fort
WEATHER_STATE=AL
HISTORY_DAYS=30

# Maximum age (minutes) before a cached forecast is considered stale
WEATHER_FORECAST_STALENESS_MINUTES=90

# ── Policy ────────────────────────────────────────────────────────────────────
# Must match the normative value in docs/PROMPTS_AND_RULES.md
CONFIDENCE_AUTO_APPLY_THRESHOLD=0.70
MAX_AUTO_ADJUSTMENT_PCT=20
POLICY_VERSION=v1.0.0
PROMPT_VERSION=prompt.v1.0.0

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
