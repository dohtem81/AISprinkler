# =============================================================================
# AISprinkler – Environment Variables
# Copy to .env and fill values. Never commit .env to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aisprinkler:aisprinkler@db:5432/aisprinkler
DEVICE_ID=00000000-0000-0000-0000-000000000001
BASELINE_LOOKAHEAD_DAYS=7

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Agent Runtime ─────────────────────────────────────────────────────────────
# AGENT_MODE options:
# - heuristic  -> local deterministic scaffold agent (no external LLM)
# - langchain  -> provider-backed agent (OpenAI/Anthropic/Ollama)
#
# Active:
AGENT_MODE=langchain
# Alternative:
# AGENT_MODE=heuristic

# ── AI Provider ──────────────────────────────────────────────────────────
# Provider: openai | anthropic | ollama  (default: openai)
#
# Active (for AGENT_MODE=langchain):
LLM_PROVIDER=ollama
# Alternatives:
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic

# Model override – leave blank to use the provider's default model
# openai default: gpt-4.1 | anthropic default: claude-3-7-sonnet | ollama default: llama3.2
#
# Active:
LLM_MODEL=llama3.2
# Alternatives:
# LLM_MODEL=gpt-4.1
# LLM_MODEL=claude-3-7-sonnet
# LLM_MODEL=

# API keys (use only for selected provider)
# - Not required when LLM_PROVIDER=ollama
# - Required when LLM_PROVIDER=openai/anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Examples:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (only when LLM_PROVIDER=ollama) ────────────────────────────────
# Base URL of the running Ollama server (no API key required)
# Docker Compose network:
OLLAMA_BASE_URL=http://ollama:11434
# Host-run app alternative:
# OLLAMA_BASE_URL=http://localhost:11434

# ── Weather Providers ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=...
WEATHERAPI_API_KEY=...

# Primary provider: openweathermap | weatherapi
WEATHER_PRIMARY_PROVIDER=openweathermap

# Runtime weather source for use case wiring: open_meteo | synthetic
WEATHER_PROVIDER=open_meteo

# Location parameters for weather fetches and persistence
WEATHER_LAT=30.676
WEATHER_LON=-87.914
WEATHER_ZIPCODE=36527
WEATHER_CITY=Spanish Fort
WEATHER_STATE=AL
HISTORY_DAYS=30

# Maximum age (minutes) before a cached forecast is considered stale
WEATHER_FORECAST_STALENESS_MINUTES=90

# ── Policy ────────────────────────────────────────────────────────────────────
# Must match the normative value in docs/PROMPTS_AND_RULES.md
CONFIDENCE_AUTO_APPLY_THRESHOLD=0.70
MAX_AUTO_ADJUSTMENT_PCT=20
POLICY_VERSION=v1.0.0
PROMPT_VERSION=prompt.v1.0.0

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SECRET_KEY=change-me-in-production
