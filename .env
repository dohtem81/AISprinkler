# =============================================================================
# AISprinkler – Environment Variables (Ollama Runtime)
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aisprinkler:aisprinkler@db:5432/aisprinkler

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── AI Provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional when using Ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Weather Providers ────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=
WEATHERAPI_API_KEY=
WEATHER_PRIMARY_PROVIDER=openweathermap
WEATHER_FORECAST_STALENESS_MINUTES=90

# ── Policy ───────────────────────────────────────────────────────────────────
CONFIDENCE_AUTO_APPLY_THRESHOLD=0.70
MAX_AUTO_ADJUSTMENT_PCT=20
POLICY_VERSION=v1.0.0
PROMPT_VERSION=prompt.v1.0.0

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
